PORT=4000
DATABASE_URL=postgresql://healthuser:123@localhost:5432/healthcare?schema=public

# JWT/verification settings for backend-issued tokens
AUTH_JWT_SECRET=your_jwt_secret_here

## Cloudflare R2 configuration
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
# Optional public base URL (e.g. https://cdn.example.com)
R2_PUBLIC_BASE_URL=

