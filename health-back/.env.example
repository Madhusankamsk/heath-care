# Copy to `.env` and adjust.

# Server
PORT=4000
NODE_ENV=development

# Database (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Auth
AUTH_JWT_SECRET=change-me-use-long-random-string

# Transactional email (optional — leave EMAIL_ENABLED unset or false for local dev)
# EMAIL_ENABLED=true
# EMAIL_FROM="Health Scan <support@healthscan.com>"
# EMAIL_LOG_ONLY=false
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# Cloudflare R2 (optional — file routes)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_BASE_URL=
