# Copy to `.env` and adjust.

# Server
PORT=4000
NODE_ENV=development

# Database (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Auth
AUTH_JWT_SECRET=change-me-use-long-random-string

# Public URL of the Next.js app (password reset links). Required in production.
# Dev falls back to http://localhost:3000 when unset.
# PASSWORD_RESET_APP_URL=http://localhost:3000

# Transactional email (optional — leave EMAIL_ENABLED unset or false for local dev)
# EMAIL_ENABLED=true
# Sender: set EMAIL_FROM and/or SMTP_FROM (either works; EMAIL_FROM wins if both set)
# EMAIL_FROM="Health Scan <support@healthscan.com>"
# SMTP_FROM=noreply@example.com
# EMAIL_LOG_ONLY=false
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# Cloudinary (file uploads — diagnostic reports, payment slips)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
