// Prisma schema for Health Backend (Supabase PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. ACCESS CONTROL
model Role {
  id          String       @id @default(uuid())
  roleName    String       @unique
  description String?
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id            String           @id @default(uuid())
  permissionKey String           @unique
  roles         RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

// 2. USER MANAGEMENT (Manual Auth Users)
model User {
  id                  String          @id @default(uuid())
  fullName            String
  email               String          @unique
  password            String
  phoneNumber         String?
  baseConsultationFee Decimal         @default(0)
  roleId              String
  role                Role            @relation(fields: [roleId], references: [id])
  isActive            Boolean         @default(true)
  createdAt           DateTime        @default(now())

  teamMembers        TeamMember[]
  transfersPerformed StockTransfer[] @relation("TransferredBy")
  dispensedMedicines DispensedMedicine[]
}

// 3. DYNAMIC TEAM & FLEET
model Vehicle {
  id           String        @id @default(uuid())
  vehicleNo    String        @unique
  model        String?
  status       String        @default("Available")
  statusId     String?
  statusLookup Lookup?       @relation("VehicleStatus", fields: [statusId], references: [id])
  medicalTeams MedicalTeam[]
}

model MedicalTeam {
  id        String       @id @default(uuid())
  teamName  String?
  vehicleId String
  vehicle   Vehicle      @relation(fields: [vehicleId], references: [id])
  members   TeamMember[]
  bookings  Booking[]
}

model TeamMember {
  id        String      @id @default(uuid())
  teamId    String
  userId    String
  isLead    Boolean     @default(false)
  team      MedicalTeam @relation(fields: [teamId], references: [id])
  user      User        @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

// 4. PATIENT & VISITS
model Patient {
  id            String         @id @default(uuid())
  nicOrPassport String?        @unique
  fullName      String
  dob           DateTime?
  contactNo     String?
  gender        String?
  genderId      String?
  genderLookup  Lookup?        @relation("PatientGender", fields: [genderId], references: [id])
  address       String?
  bookings      Booking[]
  opdQueue      OpdQueue[]
  visitRecords  VisitRecord[]
  invoices      Invoice[]
}

model Booking {
  id            String       @id @default(uuid())
  patientId     String
  teamId        String
  scheduledDate DateTime
  status        String       @default("Pending")
  statusId      String?
  statusLookup  Lookup?      @relation("BookingStatus", fields: [statusId], references: [id])
   locationGps   String?
  patient       Patient      @relation(fields: [patientId], references: [id])
  team          MedicalTeam  @relation(fields: [teamId], references: [id])
  visitRecord   VisitRecord?
  invoice       Invoice[]
}

model VisitRecord {
  id          String              @id @default(uuid())
  bookingId   String              @unique
  patientId   String
  diagnosis   String?
  vitals      Json?
  clinicalNotes String?
  completedAt   DateTime?
  booking     Booking             @relation(fields: [bookingId], references: [id])
  patient     Patient             @relation(fields: [patientId], references: [id])
  medicines   DispensedMedicine[]
}

// 5. INVENTORY & DISPENSING
model Medicine {
  id                 String             @id @default(uuid())
  name               String
  genericName        String?
  sellingPrice       Decimal
  uom                String?
  uomId              String?
  uomLookup          Lookup?            @relation("MedicineUom", fields: [uomId], references: [id])
  minStockLevel      Int?
  inventoryBatches   InventoryBatch[]
  stockTransfers     StockTransfer[]
  dispensedMedicines DispensedMedicine[]
}

model InventoryBatch {
  id           String          @id @default(uuid())
  medicineId   String
  batchNo      String
  expiryDate   DateTime
  quantity     Int
  buyingPrice  Decimal
  locationType String          // Warehouse, Vehicle, Nurse
  locationTypeId String?
  locationTypeLookup Lookup?   @relation("InventoryLocationType", fields: [locationTypeId], references: [id])
  locationId   String?         // User ID (Nurse) or Vehicle ID
  medicine     Medicine        @relation(fields: [medicineId], references: [id])
  transfers    StockTransfer[] @relation("BatchInTransfer")
  dispensings  DispensedMedicine[]
}

model StockTransfer {
  id              String         @id @default(uuid())
  medicineId      String
  batchId         String
  fromLocationId  String
  toLocationId    String
  quantity        Int
  status          String         @default("Pending")
  statusId        String?
  statusLookup    Lookup?        @relation("TransferStatus", fields: [statusId], references: [id])
  transferredById String
  medicine        Medicine       @relation(fields: [medicineId], references: [id])
  batch           InventoryBatch @relation("BatchInTransfer", fields: [batchId], references: [id])
  transferredBy   User           @relation("TransferredBy", fields: [transferredById], references: [id])
  createdAt       DateTime       @default(now())
}

model DispensedMedicine {
  id              String         @id @default(uuid())
  visitId         String
  medicineId      String
  batchId         String
  quantity        Int
  dispensedById   String
  unitPriceAtTime Decimal
  visit           VisitRecord    @relation(fields: [visitId], references: [id])
  medicine        Medicine       @relation(fields: [medicineId], references: [id])
  batch           InventoryBatch @relation(fields: [batchId], references: [id])
  dispensedBy     User           @relation(fields: [dispensedById], references: [id])
}

// 6. BILLING
model Invoice {
  id                String   @id @default(uuid())
  bookingId         String?
  patientId         String
  totalAmount       Decimal
  consultationTotal Decimal
  medicineTotal     Decimal
  travelCost        Decimal
  paymentStatus     String   @default("Unpaid")
  paymentStatusId   String?
  paymentStatusLookup Lookup? @relation("InvoicePaymentStatus", fields: [paymentStatusId], references: [id])
  booking           Booking? @relation(fields: [bookingId], references: [id])
  patient           Patient  @relation(fields: [patientId], references: [id])
  createdAt         DateTime @default(now())
}

model OpdQueue {
  id        String   @id @default(uuid())
  patientId String
  tokenNo   Int      @default(autoincrement())
  status    String   @default("Waiting")
  statusId  String?
  statusLookup Lookup? @relation("OpdStatus", fields: [statusId], references: [id])
  patient   Patient  @relation(fields: [patientId], references: [id])
  visitDate DateTime @default(now())
}

// 0. COMPANY CONFIGURATION (White-label)
model CompanySettings {
  id               String   @id @default(uuid())
  companyName      String
  companyEmail     String?
  companyPhone     String?
  companyAddress   String?
  logoUrl          String?
  primaryColor     String?
  secondaryColor   String?
  currencyCode     String?
  travelCostPerKm  Decimal  @default(0)
  taxPercentage    Decimal  @default(0)
  invoicePrefix    String   @default("INV-")
  isSetupCompleted Boolean  @default(false)
  updatedAt        DateTime @default(now())
}

// 0. LOOKUPS (Dynamic enums)
model LookupCategory {
  id           String   @id @default(uuid())
  categoryName String   @unique
  lookups      Lookup[]
}

model Lookup {
  id           String         @id @default(uuid())
  categoryId   String
  lookupKey    String
  lookupValue  String
  isActive     Boolean        @default(true)
  category     LookupCategory @relation(fields: [categoryId], references: [id])

  vehicleStatuses         Vehicle[]       @relation("VehicleStatus")
  patientGenders          Patient[]       @relation("PatientGender")
  bookingStatuses         Booking[]       @relation("BookingStatus")
  medicineUoms            Medicine[]      @relation("MedicineUom")
  inventoryLocationTypes  InventoryBatch[] @relation("InventoryLocationType")
  transferStatuses        StockTransfer[] @relation("TransferStatus")
  invoicePaymentStatuses  Invoice[]       @relation("InvoicePaymentStatus")
  opdStatuses             OpdQueue[]      @relation("OpdStatus")

  @@index([categoryId])
  @@unique([categoryId, lookupKey])
}

